<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PatientRegistration.Plugin.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="860"
             d:DesignHeight="620"
             x:Class="PatientRegistration.Plugin.Views.PatientRegistrationHomeView"
             x:DataType="vm:PatientRegistrationViewModel">

    <ScrollViewer>
        <StackPanel Margin="18" Spacing="16">
            <Border Padding="18">
                <StackPanel Spacing="4">
                    <TextBlock Text="就诊登记（无手机患者）"
                               FontSize="24"
                               FontWeight="Bold"/>
                    <TextBlock Text="先登记患者身份信息，诊疗信息可选；若不填诊疗信息，保存前需确认，医生扫码后可现场新增治疗项目。"
                               TextWrapping="Wrap"
                               FontSize="12"/>
                </StackPanel>
            </Border>

            <Border Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="患者信息（必填）" FontSize="16" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding PatientName}" Watermark="姓名"/>
                    <TextBox Text="{Binding Gender}" Watermark="性别：male / female / unknown"/>
                    <DatePicker SelectedDate="{Binding BirthDate}"/>
                    <TextBox Text="{Binding IdType}" Watermark="证件类型，例如 id_card"/>
                    <TextBox Text="{Binding IdNumber}" Watermark="证件号"/>
                    <TextBox Text="{Binding ContactPhone}" Watermark="联系方式（可选）"/>
                </StackPanel>
            </Border>

            <Border Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="诊疗信息（可选）" FontSize="16" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding AvailableDepartments}"
                              SelectedItem="{Binding SelectedDepartment}"
                              PlaceholderText="请选择科室（可选）"/>
                    <ComboBox ItemsSource="{Binding AvailableDoctors}"
                              SelectedItem="{Binding SelectedDoctor}"
                              PlaceholderText="请选择医生（可选）">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayText}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBox Text="{Binding VisitTimeRange}" Watermark="就诊时段（可选）"/>
                    <Border Padding="8">
                        <StackPanel Spacing="6">
                            <TextBlock Text="治疗项目（可多选）"/>
                            <ItemsControl ItemsSource="{Binding AvailableTreatmentItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    <TextBox Text="{Binding Notes}" Watermark="登记备注（可选）" AcceptsReturn="True" Height="72"/>

                    <CheckBox IsChecked="{Binding ConfirmEmptyDiagnosticInfo}"
                              Content="若未填写诊疗信息，已确认医生扫码时现场新增项目"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="保存并打印二维码" Click="OnSaveAndPrintClick" IsEnabled="{Binding CanSubmit}"/>
                <Button Content="仅保存" Click="OnSaveClick" IsEnabled="{Binding CanSubmit}"/>
            </StackPanel>

            <Border Padding="12">
                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"/>
            </Border>

            <Border Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="登记记录（补打）" FontSize="16" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBox Width="180"
                                 Text="{Binding SearchPatientKeyword}"
                                 Watermark="按患者姓名搜索"/>
                        <TextBox Width="160"
                                 Text="{Binding SearchIdSuffix}"
                                 Watermark="按证件后四位搜索"/>
                        <Button Content="清空筛选" Click="OnClearFilterClick"/>
                        <Button Content="刷新记录" Click="OnRefreshRecordsClick"/>
                        <Button Content="补打选中二维码" Click="OnReprintClick" IsEnabled="{Binding CanReprintSelected}"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding FilteredRecentRegistrations}"
                             SelectedItem="{Binding SelectedRegistration}"
                             Height="180">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
