<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DigitalIntelligenceBridge.ViewModels"
             x:Class="DigitalIntelligenceBridge.Views.PluginCenterView"
             x:DataType="vm:PluginCenterViewModel">

    <Design.DataContext>
        <vm:PluginCenterViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="14">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <StackPanel Spacing="4">
                <TextBlock Text="插件中心"
                           FontSize="22"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding LastUpdateStatus}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8">
                <Button Content="检查更新"
                        Classes="Primary"
                        Command="{Binding CheckUpdatesCommand}"/>
                <Button Content="刷新"
                        Classes="Secondary"
                        Command="{Binding RefreshCommand}"/>
                <Button Content="重启 DIB"
                        Classes="Secondary"
                        Command="{Binding RestartApplicationCommand}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1"
              ColumnDefinitions="*,*,*,*"
              ColumnSpacing="12">
            <Border Classes="Card" Padding="14">
                <StackPanel Spacing="4">
                    <TextBlock Text="已最新"
                               Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBlock Text="{Binding InstalledCountText}"
                               FontSize="20"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Classes="Card" Padding="14">
                <StackPanel Spacing="4">
                    <TextBlock Text="可更新"
                               Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBlock Text="{Binding UpdatableCountText}"
                               FontSize="20"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Classes="Card" Padding="14">
                <StackPanel Spacing="4">
                    <TextBlock Text="待重启"
                               Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBlock Text="{Binding PendingRestartCountText}"
                               FontSize="20"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Classes="Card" Padding="14">
                <StackPanel Spacing="4">
                    <TextBlock Text="异常"
                               Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBlock Text="{Binding FailedCountText}"
                               FontSize="20"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Classes="Card"
                Padding="14">
            <Grid RowDefinitions="Auto,*"
                  RowSpacing="8">
                <Grid ColumnDefinitions="2*,2*,*,*,*,96,2*"
                      ColumnSpacing="12">
                    <TextBlock Text="插件名称" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="插件 ID" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="2" Text="当前版本" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="3" Text="最新版本" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="4" Text="状态" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="5" Text="操作" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="6" Text="详情" FontWeight="SemiBold"/>
                </Grid>

                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding PluginItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:PluginCenterItem">
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="0,10">
                                <Grid ColumnDefinitions="2*,2*,*,*,*,96,2*"
                                      ColumnSpacing="12">
                                    <TextBlock Text="{Binding Name}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding PluginId}"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="2" Text="{Binding CurrentVersion}"/>
                                    <TextBlock Grid.Column="3" Text="{Binding LatestVersion}"/>
                                    <TextBlock Grid.Column="4" Text="{Binding Status}"/>
                                    <Button Grid.Column="5"
                                            Content="{Binding ActionText}"
                                            Command="{Binding ActionCommand}"
                                            IsVisible="{Binding CanExecuteAction}"/>
                                    <TextBlock Grid.Column="6"
                                               Text="{Binding Detail}"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>
</UserControl>
