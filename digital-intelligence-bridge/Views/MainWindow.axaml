<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DigitalIntelligenceBridge.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:DigitalIntelligenceBridge.Views"
        xmlns:prism="http://prismlibrary.com/"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="DigitalIntelligenceBridge.Views.MainWindow"
        x:Name="Root"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="DIB客户端 - Universal Tray Tool"
        Width="1200" Height="700"
        MinWidth="980" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        prism:ViewModelLocator.AutoWireViewModel="True">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <!-- 窗口样式 -->
    <Window.Styles>
        <Style Selector="TextBlock.header">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- 导航按钮样式 -->
        <Style Selector="Button.NavButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <BrushTransition Property="Foreground" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.NavButton:pointerover">
            <Setter Property="Background" Value="{DynamicResource NavHoverBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
        </Style>
        <Style Selector="Button.NavButton.active">
            <Setter Property="Background" Value="#203E78D8"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
        </Style>
        <Style Selector="Button.NavButton.SubNav">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.NavButton.SubNav:pointerover">
            <Setter Property="Background" Value="{DynamicResource NavHoverBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
        </Style>

        <Style Selector="Button.MenuToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Button.MenuToggleButton:pointerover">
            <Setter Property="Background" Value="{DynamicResource NavHoverBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
        </Style>
    </Window.Styles>

    <!-- 主布局：左侧边栏 + 中间内容区（TabControl） -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding SidebarWidth}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ========== 左侧导航栏 ========== -->
        <Border Grid.Column="0"
                Background="{DynamicResource NavBgBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- 应用标题 -->
                <Border Grid.Row="0"
                        Background="{DynamicResource NavBgBrush}"
                        Padding="{Binding SidebarHeaderPadding}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <StackPanel Spacing="5">
                            <TextBlock Text="DIB客户端"
                                      FontSize="18"
                                      FontWeight="Bold"
                                      Foreground="{DynamicResource TextMainBrush}"
                                      IsVisible="{Binding IsMenuExpanded}"/>
                            <TextBlock Text="Universal Tray Tool"
                                      FontSize="11"
                                      Opacity="0.6"
                                      Foreground="{DynamicResource TextMutedBrush}"
                                      IsVisible="{Binding IsMenuExpanded}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Classes="MenuToggleButton"
                                Command="{Binding ToggleMenuCollapseCommand}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top">
                            <TextBlock Text="{Binding MenuToggleGlyph}"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- 导航菜单 -->
                <ScrollViewer Grid.Row="1"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             Padding="{Binding SidebarScrollPadding}">
                    <StackPanel Spacing="5">
                        <!-- 核心功能分组 -->
                        <TextBlock Text="核心功能"
                                  FontSize="11"
                                  FontWeight="Bold"
                                  Foreground="{DynamicResource TextMutedBrush}"
                                  Margin="10,10,10,5"
                                  IsVisible="{Binding IsMenuExpanded}"/>

                        <ItemsControl ItemsSource="{Binding MenuItems}"
                                     x:Name="MenuItemsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:MenuItem">
                                    <Button Classes="NavButton"
                                           Classes.active="{Binding IsSelected}"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Left"
                                           Padding="{Binding #Root.((vm:MainWindowViewModel)DataContext).NavButtonPadding}"
                                           Opacity="{Binding IsInstalled, Converter={StaticResource BoolToOpacityConverter}}"
                                           Command="{Binding #Root.((vm:MainWindowViewModel)DataContext).NavigateCommand}"
                                           CommandParameter="{Binding TargetKey}">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="{Binding #Root.((vm:MainWindowViewModel)DataContext).MenuItemSpacing}"
                                                    HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Icon}"/>
                                            <TextBlock Text="{Binding Name}"
                                                       IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).IsMenuExpanded}"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Background="{DynamicResource BorderBrush}" Margin="10,15"/>

                        <!-- 设置 -->
                        <Button Classes="NavButton"
                               x:Name="SettingsButton"
                               Classes.active="{Binding #Root.((vm:MainWindowViewModel)DataContext).IsSettingsViewVisible}"
                               HorizontalAlignment="Stretch"
                               HorizontalContentAlignment="Left"
                               Padding="{Binding NavButtonPadding}"
                               Click="SettingsButton_Click">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="{Binding MenuItemSpacing}"
                                        HorizontalAlignment="Left">
                                <TextBlock Text="⚙"/>
                                <TextBlock Text="设置"
                                           IsVisible="{Binding #Root.((vm:MainWindowViewModel)DataContext).IsMenuExpanded}"/>
                            </StackPanel>
                        </Button>

                        <!-- 注：Web 应用功能已移除，将作为可选插件在后续版本提供 -->
                    </StackPanel>
                </ScrollViewer>

                <!-- 底部信息 -->
                <Border Grid.Row="2"
                        Background="{DynamicResource NavBgBrush}"
                        Padding="{Binding SidebarFooterPadding}">
                    <TextBlock Text="v1.0.0"
                              FontSize="10"
                              Opacity="0.5"
                              Foreground="{DynamicResource TextMutedBrush}"
                              HorizontalAlignment="Center"
                              IsVisible="{Binding IsMenuExpanded}"/>
                </Border>
            </Grid>
        </Border>

        <!-- ========== 中间主要内容区域（TabControl） ========== -->
        <Border Grid.Column="1" Background="{DynamicResource PageBgBrush}">
            <TabControl x:Name="MainTabControl"
                       SelectionChanged="MainTabControl_SelectionChanged"
                       ItemsSource="{Binding OpenTabs}"
                       SelectedItem="{Binding SelectedTab}"
                       Margin="12"
                       TabStripPlacement="Top">
                <TabControl.ItemTemplate>
                    <DataTemplate DataType="vm:TabItemModel">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                            <Button Content="×"
                                    Classes="Tertiary"
                                    Padding="4,2"
                                    FontSize="10"
                                    VerticalAlignment="Center"
                                    Command="{Binding #Root.((vm:MainWindowViewModel)DataContext).CloseTabCommand}"
                                    CommandParameter="{Binding}"/>
                        </StackPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate DataType="vm:TabItemModel">
                        <!-- 根据标签页类型显示不同内容 -->
                        <Grid Margin="12">
                            <!-- 首页视图 -->
                            <Border IsVisible="{Binding TabType, Converter={StaticResource TabTypeToVisibilityConverter}, ConverterParameter=Home}"
                                    Classes="Card">
                                <views:HomeView DataContext="{Binding #Root.((vm:MainWindowViewModel)DataContext).HomeDashboard}" />
                            </Border>

                            <!-- 资源中心视图 -->
                            <Border IsVisible="{Binding TabType, Converter={StaticResource TabTypeToVisibilityConverter}, ConverterParameter=ResourceCenter}"
                                    Classes="Card">
                                <views:ResourceCenterView DataContext="{Binding #Root.((vm:MainWindowViewModel)DataContext).ResourceCenter}" />
                            </Border>

                            <!-- 待办事项视图 -->
                            <Grid IsVisible="{Binding TabType, Converter={StaticResource TabTypeToVisibilityConverter}, ConverterParameter=Todo}">
                                <views:TodoView DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}" />
                            </Grid>

                            <!-- 外部插件宿主视图 -->
                            <Grid IsVisible="{Binding TabType, Converter={StaticResource TabTypeToVisibilityConverter}, ConverterParameter=PluginHost}">
                                <views:PluginHostView DataContext="{Binding Content}" />
                            </Grid>


                            <!-- 设置视图 -->
                            <Border IsVisible="{Binding TabType, Converter={StaticResource TabTypeToVisibilityConverter}, ConverterParameter=Settings}"
                                    Classes="Card">
                                <views:SettingsView />
                            </Border>

                            <!-- 患者管理视图（占位） -->
                            <Border IsVisible="{Binding TabType, Converter={StaticResource TabTypeToVisibilityConverter}, ConverterParameter=PatientMgmt}"
                                    Classes="Card">
                                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12">
                                    <StackPanel VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Spacing="15">
                                        <TextBlock Text="👤"
                                                  FontSize="64"
                                                  Opacity="0.3"
                                                  HorizontalAlignment="Center"/>
                                        <TextBlock Text="患者管理模块"
                                                  FontSize="20"
                                                  FontWeight="SemiBold"
                                                  HorizontalAlignment="Center"/>
                                        <TextBlock Text="功能开发中，敬请期待..."
                                                  FontSize="14"
                                                  Opacity="0.6"
                                                  HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Border>

                            <!-- 日程安排视图（占位） -->
                            <Border IsVisible="{Binding TabType, Converter={StaticResource TabTypeToVisibilityConverter}, ConverterParameter=Schedule}"
                                    Classes="Card">
                                <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12">
                                    <StackPanel VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Spacing="15">
                                        <TextBlock Text="📅"
                                                  FontSize="64"
                                                  Opacity="0.3"
                                                  HorizontalAlignment="Center"/>
                                        <TextBlock Text="日程安排模块"
                                                  FontSize="20"
                                                  FontWeight="SemiBold"
                                                  HorizontalAlignment="Center"/>
                                        <TextBlock Text="功能开发中，敬请期待..."
                                                  FontSize="14"
                                                  Opacity="0.6"
                                                  HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>
        </Border>
    </Grid>
</Window>
